# Server Configuration
PORT=5000
API_VERSION=v1

# Database - MongoDB Atlas with SSL
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-sales-prod?retryWrites=true&w=majority

# JWT - Use strong secrets (generated with: openssl rand -base64 48)
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# External AI Service
AI_SERVICE_API_URL=https://api.your-ai-service.com/v1
AI_SERVICE_API_KEY=REPLACE_WITH_PRODUCTION_API_KEY
AI_SERVICE_TIMEOUT=30000

# CORS - Your production frontend domain
CLIENT_URL=https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Transactional email service)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY
SMTP_FROM=noreply@yourdomain.com

# Security
BCRYPT_ROUNDS=12

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg,image/webp
UPLOAD_STORAGE_PATH=/var/data/uploads

# Redis (if using)
REDIS_URL=redis://:password@your-redis-cluster.amazonaws.com:6379

# Monitoring (optional)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
NEW_RELIC_LICENSE_KEY=your-new-relic-key