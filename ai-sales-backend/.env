# Server Configuration
PORT=5000
API_VERSION=v1

# Database - MongoDB Atlas with SSL
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-sales-prod?retryWrites=true&w=majority

# JWT - Use strong secrets (generated with: openssl rand -base64 48)
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# External AI Service
AI_SERVICE_API_URL=https://api.your-ai-service.com/v1
AI_SERVICE_API_KEY=REPLACE_WITH_PRODUCTION_API_KEY
AI_SERVICE_TIMEOUT=30000

# CORS - Your production frontend domain
CLIENT_URL=https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Transactional email service)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY
SMTP_FROM=noreply@yourdomain.com

# Security
BCRYPT_ROUNDS=12

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg,image/webp
UPLOAD_STORAGE_PATH=/var/data/uploads

# Redis (if using)
REDIS_URL=redis://:password@your-redis-cluster.amazonaws.com:6379

# Monitoring (optional)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
NEW_RELIC_LICENSE_KEY=your-new-relic-key
# OpenAI
OPENAI_API_KEY=sk-your-actual-openai-api-key

# Google Places
GOOGLE_PLACES_API_KEY=your-google-cloud-api-key

# KRA API (if available)
KRA_API_URL=https://api.kra.go.ke/v1
KRA_API_KEY=your-kra-api-key

# Market Research API (if you have one)
MARKET_RESEARCH_API_URL=https://api.marketresearch.com/v1
MARKET_RESEAR
# Kenya Admin API (public, no key needed usually)
KENYA_ADMIN_API_URL=https://kenya-administrative-boundaries-api-ken-admin-api.vercel.app/api

# Kenya Open Data (register at opendata.go.ke)
KENYA_OPEN_DATA_TOKEN=your-actual-token-from-opendata.go.ke

# NITA API (register at nita.go.ke/developers)
NITA_API_URL=https://api.nita.go.ke/v1
NITA_API_KEY=your-actual-nita-api-key

# KNBS API (register at knbs.or.ke/developer)
KNBS_API_KEY=your-actual-knbs-api-key
# M-PESA API
MPESA_API_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=your-business-shortcode

# Social Media APIs
FACEBOOK_ACCESS_TOKEN=your-facebook-page-token
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
# Weather API
OPENWEATHER_API_KEY=your-openweather-api-key

# SMTP for email reports
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ai-sales.com

# Frontend URL for email links
FRONTEND_URL=https://app.yourdomain.com
# Meta/Facebook/Instagram
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# Twitter/X
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# Google Ads
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_CUSTOMER_ID=your-google-ads-customer-id

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@ai-sales.com

# Africa's Talking (SMS)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-africastalking-username
AT_SENDER_ID=your-sender-id

# WhatsApp Business
WHATSAPP_BUSINESS_ID=your-whatsapp-business-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# TikTok
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_ADVERTISER_ID=your-tiktok-advertiser-id

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret